type Mutation {
  "Entry point for product-related mutations, including cache invalidation for products."
  Channel: ProductMutations!
  "Entry point for cart-related mutations."
  Cart: CartMutations!
  "Entry point for Checkout mutations such as create, remove, and update operations."
  Checkout: CheckoutMutations!
  "Contains all available payment-related mutations, such as initializing payments with Klarna, Stripe and Vipps, or creating Stripe payment intents."
  Payment: PaymentMutations!
  "Entry point for discount-related mutations."
  Discounts: DiscountsMutations!
}
type ProductMutations {
  "Invalidate the product cache for specific channels to ensure updated data is retrieved."
  RemoveProductsCache: RemoveProductsCacheArgsDTO!
}
type RemoveProductsCacheArgsDTO {
  success: Boolean!
}
type CartMutations {
  "Creates a new cart for the user."
  CreateCart(
    "Unique identifier for the customer session."
    customer_session_id: String!,
    "Currency in which the transactions will be performed (ISO 4217 format)."
    currency: String!,
    """
    Country code (ISO 3166-1 alpha-2, e.g., "NO" for Norway, "EN" for England) to assign the shipping origin for the shopping cart.
    """
    shipping_country: String
  ): CreateCartDTO!
  "Adds an item to the specified cart."
  AddItem(
    "Unique identifier of the cart to which the item is being added."
    cart_id: String!,
    "List of items to be added to the cart."
    line_items: [LineItemInput!]!
  ): CreateItemToCartDTO!
  "Deletes the specified cart."
  DeleteCart(
    "Unique identifier of the cart."
    cart_id: String!
  ): RemoveCartDTO!
  "Deletes an item from the specified cart."
  DeleteItem(
    "Unique identifier of the cart."
    cart_id: String!,
    "Unique identifier of the item to be removed from the cart."
    cart_item_id: String!
  ): RemoveItemToCartDTO!
  "Updates the details of the specified cart."
  UpdateCart(
    "Unique identifier of the cart."
    cart_id: String!,
    "Country code (ISO 3166-1 alpha-2) specifying the shipping destination."
    shipping_country: String!
  ): UpdateCartDTO!
  "Updates the details of an item in the specified cart."
  UpdateItem(
    "Unique identifier of the cart."
    cart_id: String!,
    "Unique identifier of the item in the cart."
    cart_item_id: String!,
    "Unique identifier of the shipping method, required if quantity is not provided."
    shipping_id: String,
    "Quantity of the item to update, required if shipping_id is not provided."
    qty: Int
  ): UpdateItemToCartDTO!
  "Updates the shipping details by supplier for the specified cart."
  UpdateShippingsBySupplier(
    "Unique identifier of the cart."
    cart_id: String!,
    "List of suppliers and their corresponding shipping methods to be updated."
    data: [DataUpdateShippingsBySupplier!]!
  ): UpdateShippingsBySupplierDTO!
}
