union administrative_division = Country | County | Province
union administrative_division2 = CountryMarkets | CountyMarkets | ProvinceMarkets | StateMarkets
"The size of the image"
enum ImageSize {
  large
  medium
  thumbnail
  full
}
input ProductsFiltersArgs {
  "Filter products by product ID."
  product_id: Int = 0
  "Filter products by category ID."
  category_id: Int = 0
  "Filter products by SKU."
  sku: String = ""
  "Filter products by barcode."
  barcode: String = ""
  "Filter products by title."
  title: String = ""
}
input LineItemInput {
  "Unique identifier for the product."
  product_id: Int! = 0
  "Quantity of the product, default is 0 if not specified."
  quantity: Int = 0
  "Variant identifier for the product, if applicable."
  variant_id: Int
}
input PriceDataInput {
  """
  Currency in ISO 4217 format (e.g., "USD", "EUR").
  """
  currency: String!
  "Tax amount for the item, default is 0 if not specified."
  tax: Float = 0
  "Unit price of the item, default is 0 if not specified."
  unit_price: Float = 0
}
input DataUpdateShippingsBySupplier {
  "Unique identifier of the supplier."
  supplier_id: Int!
  "Unique identifier of the shipping method associated with the supplier."
  shipping_id: String!
}
input AddressArgs {
  "First name of the address owner."
  first_name: String
  "Last name of the address owner."
  last_name: String
  "Phone code, typically the country calling code."
  phone_code: String
  "Phone number of the address owner."
  phone: String
  "Company name associated with the address, if applicable."
  company: String
  "Primary address line."
  address1: String
  "Secondary address line, if applicable."
  address2: String
  "City of the address."
  city: String
  "Province or state of the address."
  province: String
  "Code of the province or state."
  province_code: String
  "Country name of the address."
  country: String
  "ISO code of the country."
  country_code: String
  "Postal or ZIP code of the address."
  zip: String
  "Email address associated with the owner."
  email: String
}
"Exposes a URL that specifies the behaviour of this scalar."
directive @specifiedBy(
    "The URL that specifies the behaviour of this scalar."
    url: String!
  ) on SCALAR

