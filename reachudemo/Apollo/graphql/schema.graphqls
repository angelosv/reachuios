  "Ephemeral key for the payment intent, if requested."
  ephemeral_key: String
}
type InitPaymentVippsDTO {
  "URL for the Vipps portal."
  payment_url: String!
}
type DiscountsMutations {
  "Adds a new discount with specified details."
  AddDiscount(
    "Unique code representing the discount."
    code: String!,
    "Percentage value of the discount."
    percentage: Int!,
    "Start date of the discount."
    start_date: String!,
    "End date of the discount."
    end_date: String!,
    "Identifier for the discount type."
    type_id: Int!
  ): AddDiscountDTO!
  "Applies a discount to the specified cart."
  ApplyDiscount(
    "Unique code of the discount to be applied."
    code: String!,
    "Unique identifier of the cart where the discount will be applied."
    cart_id: String!
  ): ApplyDiscountDTO!
  "Removes an applied discount from the specified cart."
  DeleteAppliedDiscount(
    "Unique code of the discount to be removed."
    code: String!,
    "Unique identifier of the cart from which the discount will be removed."
    cart_id: String!
  ): DeleteAppliedDiscountDTO!
  "Deletes a discount by its identifier."
  DeleteDiscount(
    "Unique identifier of the discount to be deleted."
    discount_id: Int!
  ): DeleteDiscountDTO!
  "Updates the details of an existing discount."
  UpdateDiscount(
    "Unique identifier of the discount to be updated."
    discount_id: Int!,
    "Code of the discount."
    code: String = "",
    "Percentage value of the discount."
    percentage: Int = 0,
    "Start date of the discount."
    start_date: String = "",
    "End date of the discount."
    end_date: String = "",
    "List of product IDs associated with the discount."
    products: [Int!] = []
  ): UpdateDiscountDTO!
  "Verifies the validity and applicability of a discount."
  VerifyDiscount(
    "Unique identifier of the discount to verify."
    id: Int = 0,
    "Code of the discount to verify."
    code: String = ""
  ): VerifyDiscountDTO!
}
type AddDiscountDTO {
  "Unique identifier of the discount."
  id: Int!
  "Number of discounts applied."
  discount_count: Int
  "Code representing the discount."
  code: String
  "Percentage value of the discount."
  percentage: Int
  "Start date of the discount."
  start_date: String
  "End date of the discount."
  end_date: String
  "Details of the discount type."
  discount_type: DiscountTypeDTO
  "List of products associated with the discount."
  discount_product: [DiscountProductDTO!]
  "Metadata associated with the discount."
  discount_metadata: DiscountMetadataDTO
}
type ApplyDiscountDTO {
  "Indicates whether the discount was successfully applied."
  executed: Boolean!
  "Message providing details about the discount application result."
  message: String!
}
type DeleteAppliedDiscountDTO {
  "Indicates whether the discount was successfully removed."
  executed: Boolean!
  "Message providing details about the discount removal result."
  message: String!
}
type DeleteDiscountDTO {
  "Indicates whether the discount was successfully deleted."
  executed: Boolean!
  "Message providing details about the discount deletion result."
  message: String!
}
type UpdateDiscountDTO {
  "Unique identifier of the discount."
  id: Int!
  "Number of discounts applied."
  discount_count: Int
  "Code representing the discount."
  code: String
  "Percentage value of the discount."
  percentage: Int
  "Start date of the discount."
  start_date: String
  "End date of the discount."
  end_date: String
  "Details of the discount type."
  discount_type: DiscountTypeDTO
  "List of products associated with the discount."
  discount_product: [DiscountProductDTO!]
  "Metadata associated with the discount."
  discount_metadata: DiscountMetadataDTO
}
type VerifyDiscountDTO {
  "Indicates whether the discount is valid."
  valid: Boolean!
  "Message providing details about the discount verification result."
