schema {
  query: Query
  mutation: Mutation
}
type Query {
  "Entry point for querying products, categories, suppliers, and related entities."
  Channel: ProductsQueries!
  "Entry point for cart-related queries."
  Cart: CartQueries!
  "Provides access to all checkout-related queries, such as retrieving checkout details."
  Checkout: CheckoutQueries!
  "Provides access to payment-related queries."
  Payment: PaymentQueries!
  "Entry point for discount-related queries."
  Discounts: DiscountsQueries!
  "Entry point for markets-related queries."
  Markets: MarketsQueries!
}
type ProductsQueries {
  "Fetches a list of products based on the provided filters and context."
  GetProducts(
    """
    Currency code in ISO 4217 format (e.g., "USD", "EUR").
    """
    currency: String = "",
    "The size of the image to be returned."
    image_size: ImageSize = large,
    """
    ISO code of the shipping country (e.g., "US", "GB").
    """
    shipping_country_code: String = "",
    "Customer session ID associated with the products query."
    customerSessionId: String = "",
    "Indicates whether to use cached data for the products query."
    useCache: Boolean! = true
  ): [Product!]!
  "Fetches products by SKU list or other identifiers."
  Products(
    """
    Currency code in ISO 4217 format (e.g., "USD", "EUR").
    """
    currency: String = "",
    "The size of the image to be returned."
    image_size: ImageSize = large,
    """
    ISO code of the shipping country (e.g., "US", "GB").
    """
    shipping_country_code: String = "",
    "List of product IDs to filter products."
    product_ids: [Int!]! = [],
    "List of category IDs to filter products."
    category_ids: [Int!]! = [],
    "List of SKUs to filter products."
    sku_list: [String!]! = [],
    "List of barcodes to filter products."
    barcode_list: [String!]! = [],
    "Indicates whether to use cached data for the query."
    useCache: Boolean! = true,
    "Customer session ID for additional context in the query."
    customerSessionId: String = ""
  ): [Product!]!
  "Fetches paginated product data with optional filters and sorting."
  ProductsPagination(
    """
    Currency code in ISO 4217 format (e.g., "USD", "EUR").
    """
    currency: String = "",
    "The size of the image to be returned."
    image_size: ImageSize = large,
    """
    ISO code of the shipping country (e.g., "US", "GB").
    """
    shipping_country_code: String = "",
    "Number of products to fetch in the query."
    first: Int = 10,
    "Cursor to fetch products after a specific point."
    after: String,
    "Filters to apply on the products query."
    filters: ProductsFiltersArgs,
    "Customer session ID for context in the pagination query."
    customerSessionId: String = ""
  ): ProductPagination!
  "Fetches products by category ID."
  GetProductsByCategory(
    """
    Currency code in ISO 4217 format (e.g., "USD", "EUR").
    """
    currency: String = "",
    "The size of the image to be returned."
    image_size: ImageSize = large,
    """
    ISO code of the shipping country (e.g., "US", "GB").
    """
    shipping_country_code: String = "",
    "Unique identifier of the category to fetch products from."
    categoryId: Int! = 0,
    "Customer session ID associated with the products query."
    customerSessionId: String = "",
    "Indicates whether to use cached data for the products query."
    useCache: Boolean! = true
  ): [Product!]!
  "Fetches products by multiple category IDs."
  GetProductsByCategories(
    """
    Currency code in ISO 4217 format (e.g., "USD", "EUR").
    """
    currency: String = "",
    "The size of the image to be returned."
    image_size: ImageSize = large,
    """
    ISO code of the shipping country (e.g., "US", "GB").
    """
    shipping_country_code: String = "",
    "List of category IDs to fetch products from."
    categoryIds: [Int!]! = [],
    "Customer session ID associated with the products query."
    customerSessionId: String = "",
    "Indicates whether to use cached data for the products query."
    useCache: Boolean! = true
  ): [Product!]!
  "Fetches a single product by its ID."
  GetProduct(
    """
    Currency code in ISO 4217 format (e.g., "USD", "EUR").
    """
    currency: String = "",
    "The size of the image to be returned."
    image_size: ImageSize = large,
    """
    ISO code of the shipping country (e.g., "US", "GB").
    """
    shipping_country_code: String = "",
    "Stock Keeping Unit (SKU) of the product."
    sku: String,
    "Barcode of the product."
    barcode: String,
    "Unique identifier of the product."
    product_id: Int! = 0,
    "Customer session ID associated with the product query."
    customerSessionId: String = "",
    "Indicates whether to use cached data for the product query."
    useCache: Boolean! = true
  ): Product!
  "Fetches multiple products by their IDs."
  GetProductsByIds(
    """
    Currency code in ISO 4217 format (e.g., "USD", "EUR").
    """
    currency: String = "",
    "The size of the image to be returned."
    image_size: ImageSize = large,
    """
    ISO code of the shipping country (e.g., "US", "GB").
    """
    shipping_country_code: String = "",
    "List of product IDs to fetch."
    product_ids: [Int!]! = [],
    "Indicates whether to use cached data for the products query."
    useCache: Boolean! = true,
    "Customer session ID associated with the products query."
    customerSessionId: String = ""
  ): [Product!]!
  "Fetches products by their SKUs."
  GetProductBySKUs(
    """
    Currency code in ISO 4217 format (e.g., "USD", "EUR").
    """
    currency: String = "",
    "The size of the image to be returned."
    image_size: ImageSize = large,
    """
    ISO code of the shipping country (e.g., "US", "GB").
    """
    shipping_country_code: String = "",
    "Stock Keeping Unit (SKU) of the product to fetch."
    sku: String!,
    "Unique identifier of the product."
    product_id: Int,
    "Customer session ID associated with the product query."
    customerSessionId: String = "",
    "Indicates whether to use cached data for the product query."
    useCache: Boolean! = true
  ): [Product!]!
  "Fetches products by their barcodes."
  GetProductByBarcodes(
    """
    Currency code in ISO 4217 format (e.g., "USD", "EUR").
    """
    currency: String = "",
    "The size of the image to be returned."
    image_size: ImageSize = large,
    """
    ISO code of the shipping country (e.g., "US", "GB").
    """
    shipping_country_code: String = "",
    "Barcode of the product to fetch."
    barcode: String!,
    "Unique identifier of the product."
    product_id: Int,
    "Customer session ID associated with the product query."
    customerSessionId: String = "",
    "Indicates whether to use cached data for the product query."
    useCache: Boolean! = true
  ): [Product!]!
  "Fetches all available product categories."
  GetCategories: [GetCategoryDTO!]!
  "Fetches available markets for the channel."
  GetAvailableMarkets: [GetAvailableMarketsDTO!]!
  "Fetches purchase conditions for products."
  GetPurchaseConditions: GetPurchaseConditionsDTO!
  "Fetches terms and conditions for the channel."
  GetTermsAndConditions: GetTermsAndConditionsDTO!
  "Fetches all available channels for the user."
  GetChannels: [GetChannelsDTO!]!
  "Fetches products along with their taxed prices."
  GetTaxedPrices(
    "Currency code (ISO 4217) for the prices."
    currency: String = "",
    "List of product IDs for which to calculate taxed prices."
    product_ids: [Int!]! = [],
    "Country code (ISO 3166-1 alpha-2) of the shipping destination."
    shipping_country_code: String = "",
    "Customer session ID for context in the calculation."
    customerSessionId: String = ""
  ): [ProductsAndTaxes!]!
  "Fetches suppliers based on provided filters."
  GetSuppliers(
    "List of supplier IDs to fetch."
    supplier_ids: [Int!]! = []
  ): [GetSuppliersDTO!]!
  "Fetches suppliers by shipping country."
  GetSuppliersByShippingCountry(
    "List of shipping country codes to filter suppliers by."
    shipping_country: [String!]! = []
  ): [GetSuppliersByShippingCountryDTO!]!
}
type Product {
  "Unique identifier for the product."
  id: Int!
  "Title of the product."
  title: String!
  "Brand of the product."
  brand: String
  "Description of the product."
  description: String
  "Tags associated with the product."
  tags: String!
  "SKU of the product."
  sku: String!
  "Available quantity of the product."
  quantity: Int
  "Pricing details of the product."
  price: Price!
  "List of variants available for the product."
  variants: [Variant!]!
  "Barcode of the product."
  barcode: String
  "Product options such as size or color."
  options: [Option!]!
  "Categories associated with the product."
  categories: [Category!]
  "List of images for the product."
  images: [Image!]!
  "Shipping options available for the product."
  product_shipping: [ProductShipping!]
  "Supplier of the product."
  supplier: String!
  "Unique identifier for the supplier of the product."
  supplier_id: Int
  "Indicates if the product is imported."
  imported_product: Boolean
  "Referral fee associated with the product."
  referral_fee: Int
  "Indicates if product options are enabled."
  options_enabled: Boolean!
  "Indicates if the product is digital."
  digital: Boolean!
  "Origin for the product."
  origin: String!
  "Return information for the product."
  return: ReturnInfo
}
type Price {
  "Base amount of the price."
  amount: Float!
  """
  Currency code in ISO 4217 format (e.g., "USD", "EUR").
  """
  currency_code: String!
  "Total amount including taxes."
  amount_incl_taxes: Float
  "Tax amount applied to the base price."
  tax_amount: Float
  "Tax rate applied to the price."
  tax_rate: Float
  "Comparison price for the product."
  compare_at: Float
  "Comparison price including taxes."
  compare_at_incl_taxes: Float
}
type Variant {
  "Unique identifier for the variant."
  id: ID!
  "Barcode of the variant."
  barcode: String
  "Pricing information for the variant."
  price: Price!
  "Available quantity of the variant."
  quantity: Int
  "Stock Keeping Unit (SKU) of the variant."
  sku: String!
  "Title of the variant."
  title: String!
  "List of images associated with the variant."
  images: [Image!]!
}
type Image {
  "Unique identifier for the image."
  id: ID!
  "URL of the image."
  url: String!
  "Width of the image."
  width: Int
  "Height of the image."
  height: Int
  "Order in which the image is displayed."
  order: Int!
}
type Option {
  "Unique identifier for the option."
  id: ID!
  "Name of the option (e.g., size, color)."
  name: String!
  "Order of the option in the product."
  order: Int!
  "Values available for the option."
  values: String!
}
type Category {
  "Unique identifier for the category."
  id: Int!
  "Name of the category."
  name: String!
}
type ProductShipping {
  "Unique identifier for the shipping option."
  id: ID!
  "Name of the shipping option."
  name: String!
  "Description of the shipping option."
  description: String
  "Indicates whether custom pricing is enabled for the shipping option."
  custom_price_enabled: Boolean!
  "Indicates whether this is the default shipping option."
  default: Boolean!
  "List of countries supported by the shipping option."
  shipping_country: [ShippingCountry!]
}
type ShippingCountry {
  "Unique identifier for the shipping country."
  id: ID!
  "Country name of the shipping destination."
  country: String!
  "Pricing details for shipping to the country."
  price: BasePrice!
}
type BasePrice {
  "Base amount of the price."
  amount: Float!
  """
  Currency code in ISO 4217 format (e.g., "USD", "EUR").
  """
  currency_code: String!
  "Total amount including taxes."
  amount_incl_taxes: Float
  "Tax amount applied to the base price."
  tax_amount: Float
  "Tax rate applied to the price."
  tax_rate: Float
}
type ReturnInfo {
  "Indicates whether the product has a return right."
  return_right: Boolean
  "Return label details for the product."
  return_label: String
  "Cost of returning the product."
  return_cost: Float
  "Supplier-specific return policy details."
  supplier_policy: String
  "Return address details for the product."
  return_address: ReturnAddress
}
type ReturnAddress {
  "Indicates whether the return address is the same as the business address."
  same_as_business: Boolean
  "Indicates whether the return address is the same as the warehouse address."
  same_as_warehouse: Boolean
  "Country of the return address."
  country: String
  "Timezone of the return address."
  timezone: String
  "Primary return address line."
  address: String
  "Secondary return address line."
  address_2: String
  "Postal code of the return address."
  post_code: String
  "City of the return address."
  return_city: String
}
type ProductPagination {
  "List of product edges for the current page."
  edges: [ProductEdge!]!
  "Information about pagination for the product list."
  page_info: PageInfo!
  "Total count of products in the list."
  total_count: Int!
}
type ProductEdge {
  "The product node in the current edge."
  node: Product!
  "Cursor for the current product edge."
  cursor: String!
}
type PageInfo {
  "Indicates whether there is a next page of products."
  has_next_page: Boolean!
  "Indicates whether there is a previous page of products."
  has_previous_page: Boolean!
  "Cursor for the start of the current page."
  start_cursor: String
  "Cursor for the end of the current page."
  end_cursor: String
}
type GetCategoryDTO {
  "Unique identifier of the category."
  id: Int
  "Name of the category."
  name: String
  "Identifier of the parent category, if applicable."
  father_category_id: Int
  "URL of the category image."
  category_image: String
}
type GetAvailableMarketsDTO {
  "Name of the market."
  name: String
  "Official name of the market."
  official: String
  "Code of the market (ISO 3166-1 alpha-2 or alpha-3)."
  code: String
  "URL or identifier for the flag representing the market."
  flag: String
  "International phone code associated with the market."
  phone_code: String
  "Currency details for the market."
  currency: currencyDTO
  "Administrative division details associated with the market."
  administrative_division: administrative_division
}
type currencyDTO {
  """
  Currency code in ISO 4217 format (e.g., "USD").
  """
  code: String
  "Name of the currency."
  name: String
  "Symbol of the currency."
  symbol: String
}
type Country {
  "Administrative level of the division."
  level: Float
  "Name of the administrative division."
  name: String
  "List of counties or subdivisions in the country."
  values: [CountyCountry!]!
}
type CountyCountry {
  "Value representing a specific county or administrative unit."
  value: String
  "Indicates if this is the last level in the administrative hierarchy."
  last_level: Boolean
  "Next administrative level within the hierarchy."
  next_level: County
}
type County {
  "Administrative level of the division."
  level: Float
  "Name of the administrative division."
  name: String
  "List of values representing counties in the administrative division."
  values: [CountyValue!]!
}
type CountyValue {
  "Value representing counties in the administrative division."
  value: String
}
type Province {
  "Administrative level of the division."
  level: Float
  "Name of the administrative division."
  name: String
  "List of values representing provinces in the administrative division."
  values: [ProvinceValue!]!
}
type ProvinceValue {
  "Value of values representing provinces in the administrative division."
  value: String
}
type GetPurchaseConditionsDTO {
  "Headline of the purchase conditions."
  headline: String
  "Lead text or introductory section of the purchase conditions."
  lead: String
  "Last updated date of the purchase conditions."
  updated: String
  "Content elements of the purchase conditions."
  content: [ContentElement!]
}
type ContentElement {
  "Type of the content element (e.g., Paragraph, Heading)."
  type: String
  "Attributes for the content element, relevant for headings."
  attrs: AttrContentElement
  "List of text elements within the content element."
  content: [TextElement!]
}
type AttrContentElement {
  "The level of the content element, applicable to headings."
  level: Int
}
type TextElement {
  "Type of the text element (e.g., plain text)."
  type: String
  "Text content of the element."
  text: String
  "List of link marks applied to the text element."
  marks: [LinkMark!]
}
type LinkMark {
  "Type of the link mark."
  type: String
  "Attributes of the link mark."
  attrs: AttrLinkMark
}
type AttrLinkMark {
  "Hyperlink reference (href) for the link mark."
  href: String
  """
  Target attribute of the link mark (e.g., "_blank").
  """
  target: String
  "Type of the link mark (e.g., internal, external)."
  linktype: String
}
type GetTermsAndConditionsDTO {
  "Headline of the terms and conditions."
  headline: String
  "Lead or introductory text for the terms and conditions."
  lead: String
  "Last updated date for the terms and conditions."
  updated: String
  "Content elements of the terms and conditions."
  content: [ContentElementTAC!]
}
type ContentElementTAC {
  "Type of the content element, e.g., Paragraph or Heading."
  type: String
  "Attributes of the content element, applicable to headings."
  attrs: AttrContentElementTAC
  "Array of text elements within the content."
  content: [TextElementTAC!]
}
type AttrContentElementTAC {
  "Level attribute for content, applies to headings."
  level: Int
}
type TextElementTAC {
  "Type of the text element, e.g., plain text."
  type: String
  "Text content of the element."
  text: String
  "Array of link marks applied to the text element."
  marks: [LinkMarkTAC!]
}
type LinkMarkTAC {
  "Type of the link mark."
  type: String
  "Attributes of the link mark."
  attrs: AttrLinkMarkTAC
}
type AttrLinkMarkTAC {
  "Hyperlink reference (href) of the link mark."
  href: String
  """
  Target attribute of the link, e.g., "_blank".
  """
  target: String
  "Type of the link, e.g., internal or external."
  linktype: String
}
type GetChannelsDTO {
  "Unique identifier of the channel."
  channel: String!
  "Name of the channel."
  name: String!
  "Unique identifier for the channel."
  id: Int!
  "API key associated with the channel."
  api_key: String
  "Settings configuration for the channel."
  settings: settingsChennelDTO!
}
type settingsChennelDTO {
  "Indicates whether Stripe payment link is enabled for the channel."
  stripe_payment_link: Boolean!
  "Indicates whether Stripe payment intent is enabled for the channel."
  stripe_payment_intent: Boolean!
  "Indicates whether Klarna payment option is enabled for the channel."
  klarna: Boolean!
  "List of markets associated with the channel."
  markets: [String!]!
  "Indicates whether purchase conditions are required for the channel."
  purchase_conditions: Boolean!
}
type ProductsAndTaxes {
  "Unique identifier for the product."
  id: Int!
  "Title of the product."
  title: String!
  "Brand of the product."
  brand: String
  "Description of the product."
  description: String
  "Tags associated with the product."
  tags: String!
  "SKU of the product."
  sku: String!
  "Available quantity of the product."
  quantity: Int
  "Pricing details of the product."
  price: Price!
  "List of variants available for the product."
  variants: [Variant!]!
  "Barcode of the product."
  barcode: String
  "Product options such as size or color."
  options: [Option!]!
  "Categories associated with the product."
  categories: [Category!]
  "List of images for the product."
  images: [Image!]!
  "Shipping options available for the product."
  product_shipping: [ProductShipping!]
  "Supplier of the product."
  supplier: String!
  "Unique identifier for the supplier of the product."
  supplier_id: Int
  "Indicates if the product is imported."
  imported_product: Boolean
  "Referral fee associated with the product."
  referral_fee: Int
  "Indicates if product options are enabled."
  options_enabled: Boolean!
  "Indicates if the product is digital."
  digital: Boolean!
  "Origin for the product."
  origin: String!
  "Return information for the product."
  return: ReturnInfo
  taxes: [Taxes!]
}
type Taxes {
  country: String
  tax: [Tax!]
}
type Tax {
  name: String
  value: Float
  amount: Float
}
type GetSuppliersDTO {
  "Unique identifier of the supplier."
  id: Int
  "Username of the supplier."
  username: String
  "First name of the supplier."
  name: String
  "Surname of the supplier."
  surname: String
  "Phone number of the supplier."
  phone: String
  "Address of the supplier."
  address: String
  "Avatar or profile image URL of the supplier."
  avatar: String
  "Brand name associated with the supplier."
  brand_name: String
}
type GetSuppliersByShippingCountryDTO {
  "Unique identifier of the supplier."
  id: Int
  "Username of the supplier."
  username: String
  "First name of the supplier."
  name: String
  "Surname of the supplier."
  surname: String
  "Phone number of the supplier."
  phone: String
  "Address of the supplier."
  address: String
  "Avatar or profile image URL of the supplier."
  avatar: String
  "Brand name associated with the supplier."
  brand_name: String
}
type CartQueries {
  "Fetches the details of a specific cart by its ID."
  GetCart(
    "Unique identifier of the cart."
    cart_id: String!
  ): GetCartDTO!
  "Retrieves line items grouped by supplier for the specified cart."
  GetLineItemsBySupplier(
    "Unique identifier of the cart."
    cart_id: String!
  ): [GetLineItemsBySupplierDTO!]!
}
type GetCartDTO {
  "Unique identifier for the cart."
  cart_id: String!
  "Unique identifier for the customer session associated with the cart."
  customer_session_id: String!
  "ISO code of the shipping country for the cart."
  shipping_country: String
  "List of line items in the cart."
  line_items: [LineItemDTO!]!
  "Subtotal of the cart."
  subtotal: Float
  "Shipping cost for the cart."
  shipping: Float
  "Currency code for the cart (ISO 4217)."
  currency: String!
  "List of available shipping countries for the cart."
  available_shipping_countries: [String!]!
}
type LineItemDTO {
  "Unique identifier for the line item."
  id: String!
  "Supplier of the line item."
  supplier: String!
  "List of images associated with the line item."
  image: [ProductImageDTO!]
  "Stock Keeping Unit (SKU) of the line item."
  sku: String
  "Barcode of the line item."
  barcode: String
  "Brand of the line item."
  brand: String
  "Unique identifier of the product."
  product_id: Int!
  "Title of the product."
  title: String
  "Variant identifier for the product."
  variant_id: Int
  "Title of the product variant."
  variant_title: String
  "List of variant options for the product."
  variant: [VariantOptionDTO!]!
  "Quantity of the line item."
  quantity: Int!
  "Price details for the line item."
  price: PriceDataDTO!
  "Shipping details for the line item."
  shipping: ShippingDTO
  "List of available shipping options for the line item."
  available_shippings: [LineItemAvailableShippingDTO!]
}
type ProductImageDTO {
  "Unique identifier of the product image."
  id: ID!
  "URL of the product image."
  url: String!
  "Width of the product image."
  width: Int
  "Height of the product image."
  height: Int
}
type VariantOptionDTO {
  "Option name for the variant."
  option: String!
  "Option value for the variant."
  value: String!
}
type PriceDataDTO {
  "Price amount."
  amount: Float!
  "Currency code for the price (ISO 4217)."
  currency_code: String!
  "Discount applied to the price."
  discount: Float
  "Price for comparison, usually the original price."
  compare_at: Float
  "Comparison price including taxes."
  compare_at_incl_taxes: Float
  "Price amount including taxes."
  amount_incl_taxes: Float
  "Tax amount for the price."
  tax_amount: Float
  "Tax rate applied to the price."
  tax_rate: Float
}
type ShippingDTO {
  "Identifier of the shipping method."
  id: String!
  "Name of the shipping method."
  name: String!
  "Description of the shipping method."
  description: String
  "Price details for the shipping method."
  price: ShippingPriceDTO!
}
type ShippingPriceDTO {
  "Price amount for shipping."
  amount: Float!
  "Currency code for the shipping price (ISO 4217)."
  currency_code: String!
  "Shipping price including taxes."
  amount_incl_taxes: Float
  "Tax amount for shipping."
  tax_amount: Float
  "Tax rate applied to the shipping."
  tax_rate: Float
}
type LineItemAvailableShippingDTO {
  "Unique identifier of the shipping option."
  id: String
  "Name of the shipping option."
  name: String
  "Description of the shipping option."
  description: String
  "ISO code of the country for the shipping option."
  country_code: String
  "Price details for the available shipping option."
  price: PriceLineItemAvailableShippingDTO!
}
