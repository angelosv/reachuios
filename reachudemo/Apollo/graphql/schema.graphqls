  CreatePaymentIntentStripe(
    "Unique identifier for the Stripe checkout session."
    checkout_id: String!,
    "Indicates whether to return an ephemeral key for the payment intent."
    return_ephemeral_key: Boolean
  ): PaymentIntentStripeDTO!
  "Initializes a payment session with Vipps."
  CreatePaymentVipps(
    "Checkout id."
    checkout_id: String!,
    "Customer's email."
    email: String!,
    "Return url after payment"
    return_url: String!
  ): InitPaymentVippsDTO!
}
