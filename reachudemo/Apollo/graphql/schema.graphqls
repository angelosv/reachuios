type PaymentMutations {
  "Initializes a payment session with Klarna."
  CreatePaymentKlarna(
    "Unique identifier for the Klarna checkout session."
    checkout_id: String!,
    "Country code (ISO 3166-1 alpha-2) for the payment."
    country_code: String!,
    "URL to redirect after completing the payment."
    href: String!,
    "Email address of the user initiating the payment."
