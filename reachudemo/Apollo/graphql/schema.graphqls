  ): InitPaymentKlarnaDTO!
  "Initializes a payment session with Stripe."
  CreatePaymentStripe(
    "Unique identifier for the Stripe checkout session."
    checkout_id: String!,
    "URL to redirect the user upon successful payment completion."
    success_url: String!,
    "Payment method to be used for the Stripe transaction."
